#include <stdio.h>

class Animal {
    pub String name;

    pub Animal(String name) {
        this.name = name;
    }

    pub speak() {
        printf("...\n");
    }
}

class Dog inherit Animal {
    pub String breed;

    pub Dog(String name, String breed) {
        this.name = name;
        this.breed = breed;
    }

    pub bark() {
        printf("Woof!\n");
    }
}

main() -> int {
    Dog dog = new Dog("Rex", "Labrador");
    dog.bark();
    dog.speak();
}
