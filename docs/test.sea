class Animal {
    pub String name;

    pub Animal(String name) {
        this.name = name;
    }

    pub speak() {
        
    }

    pub drop() {
    }
}

interface Bark {
    pub bark();
}

class Dog inherit Animal implements Bark {
    pub Dog(String name) {
        this.name = name;
    }

    pub bark() -> String {
        return "Woof";
    }
}
